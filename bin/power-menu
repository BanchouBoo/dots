#!/bin/sh
# Power menu with fzfmenu, modify logout to match you wm

res=$(echo "logout\nreboot\nshutdown\nhibernate" | fzfmenu -i --prompt 'Power Menu>')

case $res in
    "logout")
        bspc quit || dwmc quit
        ;;
    "reboot")
        systemctl reboot
        ;;
    "shutdown")
        systemctl poweroff
        ;;
    "hibernate")
        systemctl hibernate
        ;;
esac

exit 0
