#!/bin/sh

### FUNCTIONS ###

start() {
    COMMAND=$1
    shift 1
    ARGS=$*
    test $(pgrep -u "$USER" -ic "$COMMAND") -eq 0 && $COMMAND $ARGS &
}

termstart() {
    COMMAND=$1
    shift 1
    ARGS=$*
    test $(pgrep -u "$USER" -ic "$COMMAND") -eq 0 && xst -c $COMMAND $COMMAND $ARGS &
}

#################

start-sxhkd
compton &
# $THEMEDIR/active-theme/fehbg &
"$BOOTIQUE_OUTPUT_DIR/fehbg" &

start lutris
start qbittorrent
start discord-uncrash "$BOOTIQUE_OUTPUT_DIR/discord.css"
start pulseeffects --gapplication-service

termstart weechat
