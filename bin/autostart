#!/bin/sh

start() {
	COMMAND=$1
	shift 1
	ARGS=$*
	pgrep -u "$USER" -ic "$COMMAND" > /dev/null || $COMMAND $ARGS &
}

termstart() {
	COMMAND=$1
	shift 1
	ARGS=$*
	pgrep -u "$USER" -ic "$COMMAND" > /dev/null || st -c $COMMAND $COMMAND $ARGS &
}

start-sxhkd
"$BOOTIQUE_OUTPUT_DIR/fehbg" &

start picom
start lutris
start qbittorrent
start discord-uncrash
start unclutter -idle 1
start ssh-agent -a "$HOME/.ssh/agent"

termstart weechat
