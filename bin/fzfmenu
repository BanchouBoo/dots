#!/bin/sh
# fzfmenu - fzf as dmenu replacement

input=$(mktemp -u --suffix .fzfmenu.input)
output=$(mktemp -u --suffix .fzfmenu.output)
mkfifo "$input"
mkfifo "$output"
chmod 600 "$input" "$output"

args=$*
tempstring=""
for arg in $args; do
	case $arg in
		-*)
			if [ "$tempstring" ]; then
				args=$(echo "$args" | sed "s~$tempstring~\"$tempstring\"~")
				tempstring=""
			fi
			;;
		*)
			if [ "$tempstring" ]; then
				tempstring="$tempstring $arg"
			else
				tempstring="$arg"
			fi
			;;
	esac
done
[ "$tempstring" ] && args=$(echo "$args" | sed "s~$tempstring~\"$tempstring\"~")

st -c fzfmenu -e sh -c "cat $input | fzf $args | tee $output" &

# handle ctrl+c outside child terminal window
trap 'kill $! 2>/dev/null; rm -f $input $output' EXIT

cat > "$input"
cat "$output"
