#!/bin/sh
# Maim wrapper to copy or upload a screenshot and send a notification

while getopts "u" opt; do
	case "$opt" in
		u)
			UPLOAD=true
			;;
	esac
done
maim -q -s -u -l --color="${SLOPCOLOR:-0.3,0.4,0.6,0.4}" /tmp/screenshot.png && {
    if [ "$UPLOAD" = true ]; then
        0x0 /tmp/screenshot.png
    else
		xclip -sel clip -t image/png /tmp/screenshot.png
	fi
	rm /tmp/screenshot.png
	notify-send "Copied screenshot to clipboard"
}

