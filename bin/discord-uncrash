#!/bin/sh
# Discord crashes in calls sometimes, this will run Discord if it detects it's not running
# Pass a CSS file in the first arg to work with BeautifulDiscord as well

CSS_PATH="$*"

if [ -n "$CSS_PATH" ] && [ ! -f "$CSS_PATH" ]; then
	echo "Not a valid file"
	exit 1
fi

discord_running() {
	test $(pgrep -c Discord) -gt 0
	echo $?
}

run_discord() {
	discord &
	[ "$CSS_PATH" ] && beautifuldiscord --css "$CSS_PATH"
}

if [ $(discord_running) -gt 0 ]; then
	run_discord
fi

while true; do
	if [ $(discord_running) -gt 0 ]; then
		run_discord
	fi
	sleep 1
done
