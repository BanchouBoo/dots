#!/bin/sh

cache_dir=${XDG_CACHE_HOME:-$HOME/.cache}/twitch
mkdir -p "$cache_dir"
stream_data="$cache_dir/livestreams.json"

oauth=$TWITCH_AUTH # add arg for setting

fzf_preview="jq -r '.streams[].channel | select(.name == \"{}\") | \"Title: \\(.status)\nCategory: \\(.game)\"' \"$stream_data\""

get_stream_data() {
	curl -s -o "$stream_data" -H "Accept: application/vnd.twitchtv.v5+json" \
	     -H "Authorization: OAuth $oauth" \
	     -X GET "https://api.twitch.tv/kraken/streams/followed"
}

play() {
	mpv "https://www.twitch.tv/${1}" &
}

open_chat() {
	st -c twitch-chat weechat -t --run-command "/server add twitch irc.chat.twitch.tv/6667 -nick=${TWITCH_USER} -password=oauth:${TWITCH_AUTH};/connect twitch;/set irc.server.twitch.autojoin \"#${1}\";/bar toggle nicklist;/bar toggle buflist;/set weechat.look.buffer_time_format \"\";/set weechat.look.prefix_align none;/set weechat.look.align_end_of_lines prefix;/buffer clear" &
}

close_term() {
	PPPID=$(cut -d ' ' -f 4 "/proc/$PPID/stat")
	kill "$PPPID"
}

get_stream_data
streams=$(jq -r '.streams[].channel.name' "$stream_data")
# streams=$(jq -r '.streams[].channel | "\(.name)\t\(.status)"' "$stream_data" | column --separator "	" --table)
selection=$(printf '%s' "$streams" | fzf --height 20 --preview "$fzf_preview" --preview-window top:2)
[ "$selection" ] || exit 0
play "$selection"
open_chat "$selection"
close_term
