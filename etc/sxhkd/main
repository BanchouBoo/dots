#
# wm independent hotkeys
#

# terminal emulator
super + Return
	$TERMINAL

# application launcher
super + semicolon
	fzfrun

super + shift + e
	power-menu

# get password
super + p
	bwmenu

super + shift + c
	rofi -show calc

# change theme
super + ctrl + t
    bootique -m

# ranger
super + shift + f
	$TERMINAL ranger

# firefox
super + b
	firefox

super + shift + d
	st -n "focus" -e sh -c "focus"

# booker capture
super + c
	st -n "booker" -e sh -c 'booker -a && booker -v'

# toggle mic mute and send a notification with mute status
super + m
	if amixer -c Snowball set Mic toggle | grep "\[on\]"; then \
		MUTE_MESSAGE="Mic unmuted"; \
	else \
		MUTE_MESSAGE="Mic muted"; \
	fi; \
	notify-send -t 1500 "$MUTE_MESSAGE"

super + shift + m
	amixer -D hw:SB set Master toggle

super + control + k
	printf "https://kakoune.org/why-kakoune/why-kakoune.html" | xclip -sel clip

# screen capture
{_, alt +, ctrl +,shift +} Print
	{screenshot, screenshot -u, screenshot -s,record}

# lock the screen using a background generated by corrupter
super + x
	slock

# make sxhkd reload its configuration files
super + Escape
	pkill -USR1 -x sxhkd
