#
# wm independent hotkeys
#

# terminal emulator
super + Return
	$TERMINAL

# rofi
super + {semicolon,Tab}
	rofi -show {run,window}

super + p
	bwmenu

super + shift + c
	rofi -show calc

super + ctrl + t
    bootique --menu

# ranger
super + shift + f
	xst ranger

# firefox
super + b
	firefox

# org capture
super + c
	org-capture

# org agenda
super + a
	org-agenda

# toggle mic mute and send a notification with mute status
super + m
	SOURCE=$(pactl info | grep 'Default Source' | cut -d ' ' -f3); \
	pactl set-source-mute "$SOURCE" toggle; \
	MUTE_STATUS=$(pactl list sources | grep "$SOURCE" -A 6 | tail -n1 | cut -d ' ' -f 2); \
	if [ "$MUTE_STATUS" = "no" ]; then notify-send -t 1500 "Mic unmuted"; else notify-send -t 1500 "Mic muted"; fi

super + shift + d
	feh ~/pictures/dvorak.png

super + control + k
	printf "https://kakoune.org/why-kakoune/why-kakoune.html" | xclip -sel clip

# screen capture
{_, alt +,ctrl +,shift +} Print
	{screenshot, screenshot -u,flameshot gui,record}

# lock the screen using a background generated by corrupter
super + x
	tmpbg="/tmp/screenlock.png"; \
	maim "$tmpbg"; corrupter "$tmpbg" "$tmpbg"; \
	i3lock -i "$tmpbg"; rm "$tmpbg"

# make sxhkd reload its configuration files:
super + Escape
	pkill -USR1 -x sxhkd
