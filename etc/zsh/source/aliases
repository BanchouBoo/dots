alias cp="cp -i"
alias df="df -h"
alias less="less -FR"

alias ls="ls --color -F"
alias la="ls -A"

alias copy="xclip -sel clip"
alias paste="xclip -o -sel clip"

alias :q="exit"

alias pfetch="EDITOR=kakoune pfetch"

alias i="sudo xbps-install"
alias r="sudo xbps-remove"
alias m="xbps-menu"

alias yt="newsboat -u ${XDG_CONFIG_HOME:-$HOME/.config}/newsboat/yt -c ${XDG_DATA_HOME:-$HOME/.local/share}/yt-cache.db"

export DOTNET_CLI_TELEMETRY_OPTOUT=1
